# ==============================================================================
# En produccion, definelas SOLO en el panel de Vercel (Project Settings > Env).
# ==============================================================================

# Rate limiting del formulario de contacto (Upstash Redis).
# Crear una base de datos en https://console.upstash.com y copiar credenciales REST.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Formulario de contacto (Resend). El correo real NUNCA se expone al cliente.
# CONTACT_TO_EMAIL: a donde llegan los mensajes (tu correo).
# RESEND_API_KEY: clave de https://resend.com (empieza por "re_").
# RESEND_FROM: remitente verificado. Sin dominio propio, usar el de pruebas de
#   Resend: "Portafolio <onboarding@resend.dev>" (en modo prueba solo entrega al
#   correo de tu propia cuenta Resend, que es justo CONTACT_TO_EMAIL).
CONTACT_TO_EMAIL=
RESEND_API_KEY=
RESEND_FROM=

# URL publica del sitio (para metadatos, sitemap y Open Graph).
NEXT_PUBLIC_SITE_URL=https://esteban-hernandez.vercel.app
